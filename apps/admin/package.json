{
  "name": "@dead-drop/admin",
  "version": "0.0.1",
  "private": true,
  "description": "Admin panel for dead-drop.xyz",
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3011",
    "dev:api": "npx tsx src/dev/server.ts",
    "dev:worker": "wrangler dev -c wrangler.api.toml",
    "build": "next build",
    "build:pages": "next-on-pages",
    "deploy:pages": "pnpm build:pages && wrangler pages deploy .vercel/output/static",
    "start": "next start",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "clean": "rm -rf .next coverage dist out .vercel",
    "deploy:api": "wrangler deploy -c wrangler.api.toml",
    "bootstrap-admin": "npx tsx scripts/bootstrap-admin.ts"
  },
  "dependencies": {
    "@dead-drop/engine": "workspace:*",
    "@dead-drop/ui": "workspace:*",
    "drizzle-orm": "^0.39.0",
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.12.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@cloudflare/workers-types": "^4.20260313.1",
    "@hono/node-server": "^1.19.11",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "better-sqlite3": "^12.8.0",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vercel": "^50.32.5",
    "vitest": "^3.0.0",
    "wrangler": "^4.74.0"
  }
}
