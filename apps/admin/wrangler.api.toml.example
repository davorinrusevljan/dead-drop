# API Worker deployment config for admin panel
# Deploy with: wrangler deploy -c wrangler.api.toml

name = "dead-drop-admin-api"
main = "src/worker.ts"
compatibility_date = "2024-01-01"
compatibility_flags = ["nodejs_compat"]

# Custom domain for admin API
[[routes]]
pattern = "admin-api.dead-drop.xyz/*"
zone_name = "dead-drop.xyz"

# Admin database (separate from core for security isolation)
# To find your database ID: wrangler d1 info dead-drop-admin
[[d1_databases]]
binding = "ADMIN_DB"
database_name = "dead-drop-admin"
database_id = "<YOUR-ADMIN-DB-ID>"

# Core database (read-only for stats)
# To find your database ID: wrangler d1 info dead-drop-core
[[d1_databases]]
binding = "CORE_DB"
database_name = "dead-drop-core"
database_id = "<YOUR-CORE-DB-ID>"

[vars]
ENVIRONMENT = "production"
