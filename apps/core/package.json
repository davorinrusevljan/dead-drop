{
  "name": "@dead-drop/core",
  "version": "0.0.1",
  "private": true,
  "description": "Community edition - Free tier only, Text only, D1 Database storage",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:worker": "wrangler dev",
    "build": "next build",
    "build:pages": "next-on-pages",
    "deploy:pages": "pnpm build:pages && wrangler pages deploy .vercel/output/static",
    "start": "next start",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "clean": "rm -rf .next coverage dist out .vercel",
    "deploy:api": "wrangler deploy -c wrangler.api.toml"
  },
  "dependencies": {
    "@dead-drop/engine": "workspace:*",
    "@dead-drop/ui": "workspace:*",
    "drizzle-orm": "^0.39.0",
    "hono": "^4.6.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@cloudflare/workers-types": "^4.20260313.1",
    "@hono/zod-openapi": "^0.18.0",
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.0",
    "typescript": "^5.7.3",
    "vercel": "^50.32.5",
    "vitest": "^3.0.0",
    "wrangler": "^4.74.0"
  }
}
