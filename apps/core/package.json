{
  "name": "@dead-drop/core",
  "version": "0.0.1",
  "private": true,
  "description": "Community edition - Free tier only, Text only, D1 Database storage",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:next": "next dev",
    "build": "tsc",
    "build:worker": "tsc --project tsconfig.worker.json",
    "start": "next start",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "clean": "rm -rf .next coverage dist"
  },
  "dependencies": {
    "@dead-drop/engine": "workspace:*",
    "@dead-drop/ui": "workspace:*",
    "drizzle-orm": "^0.39.0",
    "hono": "^4.6.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260313.1",
    "@hono/zod-openapi": "^0.18.0",
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0",
    "wrangler": "^4.74.0"
  }
}
